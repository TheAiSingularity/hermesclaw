# HermesClaw environment variables.
# Copy to .env and fill in:
#   cp .env.example .env
#
# .env is gitignored — your secrets stay on your machine.

# ---------- Hermes messaging platforms ----------
# Configure these via: hermes gateway setup
# (Hermes stores tokens securely in ~/.hermes/ — you don't need to set them here)

# ---------- Model file ----------
# Filename inside models/ to load (default: Qwen3.5-4B-Q4_K_M.gguf)
MODEL_FILE=Qwen3.5-4B-Q4_K_M.gguf

# ---------- GPU layers ----------
# Number of model layers to offload to GPU.
# 0 = CPU only (slow but works anywhere)
# 99 = all layers on GPU (fast, requires enough VRAM)
# Mac Metal: use 99 — llama.cpp handles Metal automatically
N_GPU_LAYERS=0
